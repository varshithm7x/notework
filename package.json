{
  "name": "nyx",
  "version": "1.0.0",
  "description": "A local-first knowledge management tool with graph-based note linking",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "notes",
    "knowledge-management",
    "markdown",
    "graph"
  ],
  "author": "Notework",
  "license": "MIT",
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.8",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@lezer/highlight": "^1.2.1",
    "d3": "^7.9.0",
    "dompurify": "^3.2.6",
    "fuse.js": "^7.1.0",
    "marked": "^15.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.2",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.nyx.app",
    "productName": "Nyx",
    "copyright": "Copyright © 2026 Nyx",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "public/icons"
    },
    "deb": {
      "priority": "optional",
      "afterInstall": "scripts/linux/after-install.sh"
    }
  }
}